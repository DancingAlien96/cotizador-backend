generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TipoCotizacion {
  TIENDA
  GUATECOMPRAS
  EMPRESAS
  CARTA
  PISCINA
}

// Etapa de seguimiento de la cotización (el "pipeline" del CRM).
enum EstadoCotizacion {
  PENDIENTE
  EN_CURSO
  CONFIRMADA
  RECHAZADA
}

// Una cotización de cualquier tipo. `data` guarda el JSON con la forma que
// maneja el frontend para ese tipo. `numero` es el folio (p. ej. empresas).
model Cotizacion {
  id            String           @id @default(uuid())
  tipo          TipoCotizacion
  numero        String?
  // Metadatos y resumen para el historial (listado ligero, sin traer `data`).
  nombre        String?
  autor         String?
  cliente       String?
  total         Float?
  fecha         String?
  // Seguimiento CRM. `motivoRechazo` solo aplica cuando estado = RECHAZADA.
  estado        EstadoCotizacion @default(PENDIENTE)
  motivoRechazo String?
  estadoAt      DateTime         @default(now())
  data          Json
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([tipo, updatedAt])
  @@index([updatedAt])
  @@index([estado, updatedAt])
}

// Secuencia de folios. `clave` permite compartir un correlativo entre varios
// tipos (p. ej. "cotizaciones" para Tienda y Empresas).
model Counter {
  clave String @id
  seq   Int    @default(0)
}

// Usuarios (para autenticación real más adelante).
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  nombre    String?
  createdAt DateTime @default(now())
}
